# Gemini API Key
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Contact Form Email Delivery (Nodemailer)
# Gmail account user (e.g. sivad5712@gmail.com)
GMAIL_USER=your_gmail_address_here@gmail.com
# Google Account generated 16-character App Password
GMAIL_APP_PASSWORD=your_google_app_password_here

# Delivery Inboxes
# The destination email address for form dispatches
CONTACT_EMAIL_TO=your_gmail_address_here@gmail.com
